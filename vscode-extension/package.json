{
  "name": "crucible-vscode",
  "displayName": "Crucible",
  "description": "Run Crucible prompt validation and optimization from VSCode.",
  "version": "0.1.0",
  "publisher": "crucible",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/darcijunior/crucible.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:crucible.validate",
    "onCommand:crucible.optimize",
    "onCommand:crucible.openDashboard",
    "onCommand:crucible.openLatestReport",
    "onCommand:crucible.selectFiles"
  ],
  "main": "./out/extension.js",
  "files": [
    "out",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "contributes": {
    "commands": [
      {
        "command": "crucible.validate",
        "title": "Crucible: Validate Prompt"
      },
      {
        "command": "crucible.optimize",
        "title": "Crucible: Optimize Prompt"
      },
      {
        "command": "crucible.openDashboard",
        "title": "Crucible: Open Dashboard"
      },
      {
        "command": "crucible.openLatestReport",
        "title": "Crucible: Open Latest HTML Report"
      },
      {
        "command": "crucible.selectFiles",
        "title": "Crucible: Select Prompt, Gabarito and Config"
      }
    ],
    "configuration": {
      "title": "Crucible",
      "properties": {
        "crucible.command": {
          "type": "string",
          "default": "uv run crucible",
          "description": "Command prefix used to run Crucible."
        },
        "crucible.configPath": {
          "type": "string",
          "default": "config.yaml",
          "description": "Path to Crucible config relative to the workspace root."
        },
        "crucible.promptPath": {
          "type": "string",
          "default": "prompt.txt",
          "description": "Path to prompt file relative to the workspace root."
        },
        "crucible.gabaritoPath": {
          "type": "string",
          "default": "gabarito.yaml",
          "description": "Path to gabarito file relative to the workspace root."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package --no-dependencies",
    "publish:vsce": "vsce publish --pat \"$VSCE_PAT\"",
    "publish:ovsx": "ovsx publish --pat \"$OVSX_PAT\""
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.2",
    "ovsx": "^0.10.4",
    "typescript": "^5.7.0"
  }
}
